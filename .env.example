# Local environment (optional — docker-compose sets most values)
LOG_LEVEL=INFO

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=data-quality
INCOMING_PREFIX=incoming

# Generator (docker compose --profile tools)
FILES_PER_BATCH=50
GENERATOR_INVALID_RATIO=0.3
DURATION_SEC=120
BATCH_INTERVAL=30

# Email (Mailhog in local stack)
SMTP_HOST=mailhog
SMTP_PORT=1025
EMAIL_SENDER=data-quality@example.com
EMAIL_RECIPIENTS=team@example.com
SMTP_USE_TLS=false
